# hand-written design docs there (ARCHITECTURE, MECHANISM, PRIVACY, ...), so it
# is intentionally tracked.

# Dotenv file
.env

# Generated blueprint files
blueprint.json
blueprint.lock

# Soldeer dependencies
dependencies/
